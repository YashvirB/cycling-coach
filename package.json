{
  "name": "enduragent-monorepo",
  "version": "0.0.0-private",
  "private": true,
  "description": "Multi-sport AI coaching agent platform — workspace root.",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env packages/cycling-coach/src/index.ts",
    "setup": "tsx --env-file=.env packages/cycling-coach/src/index.ts setup",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "oxlint packages/",
    "fmt": "oxfmt packages/",
    "fmt:check": "oxfmt --check packages/",
    "check": "pnpm -r build && pnpm -r check && pnpm check:types && oxlint packages/ && pnpm check:trademarks && pnpm check:fixture-privacy && pnpm check:registry-isolation && pnpm check:changeset-userfacing",
    "check:types": "tsc -p tsconfig.check.json",
    "check:trademarks": "tsx tools/check-trademarks.ts",
    "check:fixture-privacy": "tsx tools/check-fixture-privacy.ts",
    "check:registry-isolation": "tsx tools/check-registry-isolation.ts",
    "check:changeset-userfacing": "tsx tools/check-changeset-user-facing.ts",
    "release-version": "changeset version && tsx tools/bump-binaries-to-calver.ts",
    "snapshot:section-11": "tsx tools/snapshot-section-11.ts",
    "check-parity": "tsx tools/check-metric-parity.ts",
    "fuzz-parity": "tsx tools/fuzz-parity.ts",
    "coverage:reference": "tsx tools/measure-reference-coverage.ts",
    "usage:baseline": "tsx tools/usage-baseline.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@enduragent/core": "workspace:*",
    "@enduragent/sport-cycling": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "intervals-icu-api": "0.1.2",
    "msw": "^2.13.3",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "pyodide": "^0.29.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.6.3+sha512.bb45e34d50a9a76e858a95837301bfb6bd6d35aea2c5d52094fa497a467c43f5c440103ce2511e9e0a2f89c3d6071baac3358fc68ac6fb75e2ceb3d2736065e6",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "esbuild",
      "msw",
      "protobufjs"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yerzhansa/cycling-coach.git"
  }
}
