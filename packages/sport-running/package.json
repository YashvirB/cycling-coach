{
  "name": "@enduragent/sport-running",
  "version": "0.1.0",
  "private": true,
  "description": "Running sport package — critical-speed-anchored pace zones, soul, skills, tools. Implements the Sport contract from @enduragent/core.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "npm run codegen && tsup",
